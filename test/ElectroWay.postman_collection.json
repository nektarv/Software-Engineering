    {
      "name": "reserve1",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Successful POST request\", function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
              "});",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Get current time",
              "let now = new Date();",
              "",
              "// Add 5 minutes for start time",
              "let start = new Date(now.getTime() + 5 * 60000);",
              "",
              "// Add 10 minutes for end time",
              "let end = new Date(now.getTime() + 10 * 60000);",
              "",
              "// Format as YYYY-MM-DD HH:mm",
              "function formatDate(date) {",
              "    let year = date.getFullYear();",
              "    let month = String(date.getMonth() + 1).padStart(2, '0');",
              "    let day = String(date.getDate()).padStart(2, '0');",
              "    let hours = String(date.getHours()).padStart(2, '0');",
              "    let minutes = String(date.getMinutes()).padStart(2, '0');",
              "    ",
              "    return `${year}-${month}-${day} ${hours}:${minutes}`;",
              "}",
              "",
              "function formatOnlyDate(date) {",
              "    let year = date.getFullYear();",
              "    let month = String(date.getMonth() + 1).padStart(2, '0');",
              "    let day = String(date.getDate()).padStart(2, '0');",
              "",
              "    return `${year}${month}${day}`;",
              "}",
              "",
              "pm.environment.set(\"s1\", formatDate(start));",
              "pm.environment.set(\"e1\", formatDate(end));",
              "pm.environment.set(\"s1ps\", formatOnlyDate(start));",
              "pm.environment.set(\"e1ps\", formatOnlyDate(end));",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
